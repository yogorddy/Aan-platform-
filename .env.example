# ==============================================================================
# AAN IDENTITY PLATFORM — ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' inside the project root for local development.
# e.g., cp .env.example .env
# Do not commit real secrets or credentials to your Git repository.

# ------------------------------------------------------------------------------
# 1. CORE API & PLATFORM CONFIGURATION (Automatically set in AI Studio at runtime)
# ------------------------------------------------------------------------------

# GEMINI_API_KEY: Required for Gemini AI and LLM API capabilities.
# In AI Studio, this key is automatically injected at runtime from the Secrets panel.
# For manual local runs, paste your Gemini API key from Google AI Studio.
# Format: AIzaSy...
GEMINI_API_KEY=""

# APP_URL: The self-referential base URL where this application is hosted.
# In AI Studio, this is automatically set to the Cloud Run ingress URL.
# Used for OAuth callbacks, self-referential API links, and webhook signatures.
# Default for local running is http://localhost:3000
APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION (Supabase PostgreSQL Client)
# ------------------------------------------------------------------------------
# NOTE: If these variables are left empty, the AAN Platform automatically boots
# using the in-memory stateful mock database (Development Sandbox Mode).
# To activate durable cloud persistence, populate both values.

# SUPABASE_URL: The direct API URL for your Supabase project.
# Find this in your Supabase Dashboard under: Settings -> API.
# Format: https://your-project-id.supabase.co
SUPABASE_URL=""

# SUPABASE_SERVICE_ROLE_KEY: Service-Role JWT token for administrative query authorization.
# WARNING: Keep this secret safe! This key bypasses Row-Level Security (RLS) and is
# strictly for server-side operations only. NEVER prefix this with VITE_.
# Find this in your Supabase Dashboard under: Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=""

# SUPABASE_ANON_KEY: Public anonymous key (optional, used if client-side direct queries are required).
# Find this in your Supabase Dashboard under: Settings -> API -> anon public.
SUPABASE_ANON_KEY=""

# ------------------------------------------------------------------------------
# 3. FEATURE FLAGS & TOGGLES (Client and Server)
# ------------------------------------------------------------------------------

# ACADEMY_ENABLED: Feature flag to toggle AAN Academy visibility in the public interface.
# Accepts: 'true' (visible) or 'false' (hidden, accessible directly at /academy)
# Default is 'false' for MVPs.
ACADEMY_ENABLED=false
VITE_ACADEMY_ENABLED=false

# BRAND_ENABLED: Feature flag to toggle Brandbook / Core Brand Assets visibility in the public interface.
# Accepts: 'true' (visible) or 'false' (hidden, accessible directly at /brand)
# Default is 'false' for MVPs.
BRAND_ENABLED=false
VITE_BRAND_ENABLED=false

# ------------------------------------------------------------------------------
# 4. INTEGRATION REQUESTS & NOTIFICATIONS
# ------------------------------------------------------------------------------

# NEXT_PUBLIC_SUPABASE_URL: Alternative public key or direct API URL for client-side / direct integration.
NEXT_PUBLIC_SUPABASE_URL=""

# NEXT_PUBLIC_SUPABASE_ANON_KEY: Client-side anonymous access key for Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# AAN_ADMIN_EMAIL: The administrator email address where integration requests notifications should be sent/logged.
AAN_ADMIN_EMAIL="admin@aan.network"
